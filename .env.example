# =============================================================================
# DERIM Middleware - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.

# --- Application Settings ---
APP_NAME=derim-middleware
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Storage Backend ---
# Options: "influxdb" or "sqlite"
STORAGE_BACKEND=sqlite

# --- InfluxDB Settings ---
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=my-super-secret-token
INFLUXDB_ORG=derim
INFLUXDB_BUCKET=derim_telemetry

# --- SQLite Settings (fallback) ---
SQLITE_DB_PATH=./data/derim.db

# --- Modbus Adapter ---
MODBUS_HOST=127.0.0.1
MODBUS_PORT=502
MODBUS_UNIT_ID=1
MODBUS_PROTOCOL=tcp

# --- MQTT Adapter ---
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=derim/devices

# --- SunSpec Adapter ---
SUNSPEC_HOST=127.0.0.1
SUNSPEC_PORT=502
SUNSPEC_SLAVE_ID=1

# --- OCPP Adapter ---
OCPP_WS_URL=ws://localhost:9000
OCPP_CHARGE_POINT_ID=CP001

# --- Digital Twin / ML ---
MODEL_SAVE_DIR=./saved_models
FORECAST_HORIZON_HOURS=24
LSTM_EPOCHS=50
LSTM_BATCH_SIZE=32
LSTM_SEQUENCE_LENGTH=96

# --- Docker / Deployment ---
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=adminpassword
DOCKER_INFLUXDB_INIT_ORG=derim
DOCKER_INFLUXDB_INIT_BUCKET=derim_telemetry
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=my-super-secret-token
